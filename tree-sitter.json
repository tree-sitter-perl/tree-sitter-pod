{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "pod",
      "camelcase": "Pod",
      "scope": "source.pod",
      "path": ".",
      "file-types": [
        "pod"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "Artistic-2.0",
    "description": "A tree-sitter parser for POD",
    "authors": [
      {
        "name": "leonerd"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter-perl/tree-sitter-pod"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
